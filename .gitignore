# =============================================================================
# databricks-medicare-lakehouse — .gitignore
# Professional Data Engineering & ML Ops Configuration
# =============================================================================

# 1. CORE PYTHON & VIRTUAL ENVIRONMENTS
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.env
.venv
env/
venv/
ENV/
.conda/
.pytest_cache/
.mypy_cache/
.coverage

# 2. DATA FILES (Never commit raw or processed data)
# -----------------------------------------------------------------------------
data/
*.csv
*.parquet
*.avro
*.orc
*.json.gz
*.csv.gz
*.db
*.sqlite
spark-warehouse/
_delta_log/
*.checkpoint.parquet

# 3. MLFLOW & MODEL ARTIFACTS
# -----------------------------------------------------------------------------
mlruns/
mlartifacts/
*.joblib
*.pkl
*.pickle
*.h5
*.onnx

# 4. NOTEBOOKS & IDE
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
.vscode/
.idea/
*.code-workspace
.DS_Store
Thumbs.db

# NOTE: Removed *.ipynb from here so your notebooks can be tracked.
# We only ignore the hidden checkpoints folder above.

# 5. CREDENTIALS & SECRETS (STRICT PROTECTION)
# -----------------------------------------------------------------------------
.env*
!.env.example
secrets.*
*_secrets.*
*secret*
*credential*
*password*
*api_key*
kaggle.json
.aws/
.azure/
.databrickscfg
*.pem
*.key

# 6. DATABRICKS SPECIFIC
# -----------------------------------------------------------------------------
.databricks/
databricks.yml.local
cluster_init*.sh

# 7. LOGS & TEMPS
# -----------------------------------------------------------------------------
*.log
logs/
temp/
tmp/