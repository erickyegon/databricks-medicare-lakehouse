# =============================================================================
# databricks-medicare-lakehouse — .gitignore
# Python · Databricks · Delta Lake · MLflow · XGBoost · SHAP
# =============================================================================


# =============================================================================
# PYTHON
# =============================================================================

# Bytecode
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
.conda/
conda-env/

# PyInstaller
*.manifest
*.spec

# Unit test / coverage
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
pytestdebug.log
htmlcov/

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.pyre/


# =============================================================================
# DATABRICKS & SPARK
# =============================================================================

# Databricks workspace sync artifacts
.databricks/
.databricks-connect
databricks.yml.local

# Local Spark checkpoints and shuffle files
spark-warehouse/
derby.log
metastore_db/

# Delta Lake local artifacts (generated during pipeline runs)
_delta_log/
*.checkpoint.parquet

# Databricks Connect local config (contains cluster IDs / tokens)
~/.databricks-connect

# Cluster init scripts with credentials
cluster_init*.sh


# =============================================================================
# DATA FILES — never commit raw or processed data
# =============================================================================

# Raw landing zone (generated by cms_claims_generator.py)
data/raw/
data/processed/
data/landing/

# CSV/Parquet data files
*.csv
*.parquet
*.avro
*.orc
*.json.gz
*.csv.gz

# Delta table directories (local dev only)
delta/
/delta/

# Temporary data dumps
*.dump
*.sql.bak


# =============================================================================
# MLFLOW
# =============================================================================

# Local MLflow tracking server artifacts
mlruns/
mlartifacts/
mlflow.db

# Model artifacts (large binaries — use MLflow Registry instead)
*.joblib
*.pkl
*.pickle
*.h5
*.hdf5
*.pt
*.pth
*.onnx
*.mlmodel

# MLflow experiment exports
mlflow_export/


# =============================================================================
# CREDENTIALS & SECRETS — critical: never commit these
# =============================================================================

# Environment variable files
.env
.env.*
.env.local
.env.production
*.env

# Kaggle API credentials (used in Databricks challenge setup)
kaggle.json
.kaggle/

# AWS credentials
.aws/credentials
.aws/config
aws_credentials.json

# Azure credentials
.azure/
azure_credentials.json
service_principal.json

# Databricks personal access tokens
.databrickscfg
databricks_token.txt
pat_token.txt

# Any file named secrets
secrets.*
*_secrets.*
*secret*
*credential*
*password*
*api_key*

# SSH keys
*.pem
*.key
id_rsa
id_ed25519


# =============================================================================
# REPORTS & GENERATED OUTPUTS
# =============================================================================

# Pipeline-generated reports (regenerate from pipeline run)
reports/
outputs/

# SHAP plots and MLflow artifacts (logged to MLflow — not git)
*.png
*.jpg
*.jpeg
*.svg
*.pdf

# Except README images and docs diagrams — keep those
!docs/*.png
!docs/*.svg
!assets/*.png

# Jupyter notebook checkpoints
.ipynb_checkpoints/
*.ipynb


# =============================================================================
# IDE & EDITORS
# =============================================================================

# VSCode
.vscode/
*.code-workspace

# PyCharm / IntelliJ
.idea/
*.iml
*.iws
*.ipr
out/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Emacs
*.swp
*.swo
*~
\#*\#
.\#*

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/


# =============================================================================
# LOGS
# =============================================================================

*.log
*.log.*
logs/
log/
pipeline.log
spark.log


# =============================================================================
# TEMPORARY & SCRATCH FILES
# =============================================================================

# Temp files from pipeline development
/tmp/
temp/
scratch/
*.tmp
*.bak
*.orig
*.rej

# Profiling output
*.prof
*.lprof


# =============================================================================
# WHAT IS INTENTIONALLY TRACKED (do not add to .gitignore)
# =============================================================================
# ✅ config/pipeline_config.py         — central config (no secrets)
# ✅ src/**/*.py                        — all source modules
# ✅ notebooks/*.py                     — all Databricks notebooks
# ✅ tests/*.py                         — all unit tests
# ✅ workflows/pipeline_workflow.json   — Workflow DAG definition
# ✅ docs/SETUP.md                      — setup guide
# ✅ requirements.txt                   — pip dependencies
# ✅ README.md                          — project documentation
# ✅ .gitignore                         — this file
